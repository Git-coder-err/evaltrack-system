# ===========================================
# EvalTrack Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your actual values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=production
PORT=3000

# ===========================================
# DATABASE CONFIGURATION (MySQL)
# ===========================================
# Update these with your MySQL database credentials
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=evaltrack

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# GROQ AI API KEYS
# ===========================================
# Comma-separated list of API keys
GROQ_API_KEYS=your-groq-api-key-1,your-groq-api-key-2

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ===========================================
# FIREBASE CONFIGURATION (Optional)
# ===========================================
# These are used if you have Firebase Admin SDK configured
# FIREBASE_PROJECT_ID=evaltrack-system
# FIREBASE_PRIVATE_KEY_ID=your-private-key-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-client-email

# ===========================================
# SQLITE DATABASE (Alternative to MySQL)
# ===========================================
# Uncomment if using SQLite instead of MySQL
# SQLITE_PATH=./data/evaltrack.db
